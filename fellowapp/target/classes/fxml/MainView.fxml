<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
    maxHeight="-Infinity" maxWidth="-Infinity"
    minHeight="-Infinity" minWidth="-Infinity"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.fellow.app.controller.MainController"
    styleClass="app-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar">
            <Label text="Fellow" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="navButtonHome" text="Home" onAction="#showHome" styleClass="nav-button selected-nav-button"/>
            <Button fx:id="navButtonCalendar" text="Calendar" onAction="#showCalendar" styleClass="nav-button"/>
            <Button fx:id="navButtonPomodoro" text="Pomodoro" onAction="#showPomodoro" styleClass="nav-button"/>
            <Button fx:id="navButtonTodo" text="Todo" onAction="#showTodo" styleClass="nav-button"/>
            <Button fx:id="navButtonStats" text="Statistics" onAction="#showStatistics" styleClass="nav-button"/>
        </HBox>
    </top>

    <center>
        <TabPane fx:id="mainTabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 BorderPane.alignment="CENTER">
            <tabs>

                <!-- ① HOME — first tab, selected on startup -->
                <Tab fx:id="tabHome" text="Home">
                    <content>
                        <fx:include fx:id="homeView" source="HomeView.fxml"/>
                    </content>
                </Tab>

                <!-- ② CALENDAR -->
                <Tab fx:id="tabCalendar" text="Calendar">
                    <content>
                        <fx:include fx:id="calendarView" source="CalendarView.fxml"/>
                    </content>
                </Tab>

                <!-- ③ POMODORO — unchanged, fully working -->
                <Tab fx:id="tabPomodoro" text="Pomodoro">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0">
                            <children>
                                <VBox alignment="CENTER" spacing="40.0"
                                      AnchorPane.bottomAnchor="0.0"
                                      AnchorPane.leftAnchor="0.0"
                                      AnchorPane.rightAnchor="0.0"
                                      AnchorPane.topAnchor="0.0">
                                    <children>
                                        <HBox alignment="CENTER" spacing="30.0">
                                            <children>
                                                <Button mnemonicParsing="false" onAction="#handleDecrementTime" text="-" styleClass="round-icon-button"/>
                                                <Label fx:id="timerLabel" text="25:00" textAlignment="CENTER" minWidth="220" alignment="CENTER">
                                                    <font>
                                                        <Font name="System Bold" size="80.0"/>
                                                    </font>
                                                </Label>
                                                <Button mnemonicParsing="false" onAction="#handleIncrementTime" text="+" styleClass="round-icon-button"/>
                                            </children>
                                        </HBox>
                                        <HBox alignment="CENTER" nodeOrientation="RIGHT_TO_LEFT" spacing="20.0">
                                            <children>
                                                <Button fx:id="resetButton" mnemonicParsing="false" onAction="#handleReset" styleClass="button-reset" text="Reset"/>
                                                <Button fx:id="pauseButton" mnemonicParsing="false" onAction="#handlePause" styleClass="button-pause" text="Pause"/>
                                                <Button fx:id="startButton" mnemonicParsing="false" onAction="#handleStart" styleClass="button-start" text="Start"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                
                                <Button AnchorPane.topAnchor="15.0" AnchorPane.rightAnchor="15.0" mnemonicParsing="false" onAction="#handleMiniMode" text="⤢" styleClass="icon-button" />
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ④ TODO -->
                <Tab fx:id="tabTodo" text="Todo">
                    <content>
                        <fx:include fx:id="todoView" source="TodoView.fxml"/>
                    </content>
                </Tab>

                <!-- ⑤ STATISTICS — empty for now -->
                <Tab fx:id="tabStats" text="Statistics">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0"/>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="8" styleClass="bottom-bar">
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="themeToggleButton"
                    mnemonicParsing="false"
                    onAction="#handleThemeToggle"
                    text="Light Mode"
                    styleClass="theme-toggle-button"/>
        </HBox>
    </bottom>
</BorderPane>