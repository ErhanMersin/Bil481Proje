<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<BorderPane
    maxHeight="-Infinity" maxWidth="-Infinity"
    minHeight="-Infinity" minWidth="-Infinity"
    prefHeight="700.0" prefWidth="1000.0"
    stylesheets="@../css/style.css"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.fellow.app.controller.MainController">

    <center>
        <TabPane fx:id="mainTabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 BorderPane.alignment="CENTER">
            <tabs>

                <!-- ① HOME — first tab, selected on startup -->
                <Tab fx:id="tabHome" text="Home">
                    <content>
                        <fx:include fx:id="homeView" source="HomeView.fxml"/>
                    </content>
                </Tab>

                <!-- ② CALENDAR — empty for now -->
                <Tab fx:id="tabCalendar" text="Calendar">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0"
                                    prefHeight="180.0" prefWidth="200.0"/>
                    </content>
                </Tab>

                <!-- ③ POMODORO — unchanged, fully working -->
                <Tab fx:id="tabPomodoro" text="Pomodoro">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0"
                                    prefHeight="180.0" prefWidth="200.0">
                            <children>
                                <VBox alignment="CENTER" spacing="40.0"
                                      AnchorPane.bottomAnchor="0.0"
                                      AnchorPane.leftAnchor="0.0"
                                      AnchorPane.rightAnchor="0.0"
                                      AnchorPane.topAnchor="0.0">
                                    <children>
                                        <Label fx:id="timerLabel" text="25:00" textAlignment="CENTER">
                                            <font>
                                                <Font name="System Bold" size="80.0"/>
                                            </font>
                                        </Label>
                                        <HBox alignment="CENTER" nodeOrientation="RIGHT_TO_LEFT" spacing="20.0">
                                            <children>
                                                <Button fx:id="resetButton" mnemonicParsing="false" onAction="#handleReset" styleClass="button-reset" text="Reset"/>
                                                <Button fx:id="pauseButton" mnemonicParsing="false" onAction="#handlePause" styleClass="button-pause" text="Pause"/>
                                                <Button fx:id="startButton" mnemonicParsing="false" onAction="#handleStart" styleClass="button-start" text="Start"/>
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                            </children>
                        </AnchorPane>
                    </content>
                </Tab>

                <!-- ④ TODO — empty for now -->
                <Tab fx:id="tabTodo" text="Todo">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0"
                                    prefHeight="180.0" prefWidth="200.0"/>
                    </content>
                </Tab>

                <!-- ⑤ STATISTICS — empty for now -->
                <Tab fx:id="tabStats" text="Statistics">
                    <content>
                        <AnchorPane minHeight="0.0" minWidth="0.0"
                                    prefHeight="180.0" prefWidth="200.0"/>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>
</BorderPane>