<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    maxHeight="-Infinity" maxWidth="-Infinity"
    minHeight="-Infinity" minWidth="-Infinity"
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.fellow.app.controller.MainController"
    styleClass="app-root">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="12" styleClass="top-bar">
            <Label text="Fellow" styleClass="app-title"/>
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="navButtonHome" text="Home" onAction="#showHome" styleClass="nav-button selected-nav-button"/>
            <Button fx:id="navButtonCourses" text="Courses" onAction="#showCourses" styleClass="nav-button"/>
            <Button fx:id="navButtonCalendar" text="Calendar" onAction="#showCalendar" styleClass="nav-button"/>
            <Button fx:id="navButtonPomodoro" text="Timer" onAction="#showPomodoro" styleClass="nav-button"/>
            <Button fx:id="navButtonTodo" text="ToDo" onAction="#showTodo" styleClass="nav-button"/>
            <Button fx:id="navButtonStats" text="Statistics" onAction="#showStatistics" styleClass="nav-button"/>
            
            <!-- Mini Timer Widget -->
            <VBox fx:id="miniTimerContainer" styleClass="mini-timer-container" visible="false" spacing="4">
                <Label fx:id="miniTimerLabel" text="25:00" styleClass="mini-timer-label"/>
            </VBox>
        </HBox> 
    </top>

    <center>
        <TabPane fx:id="mainTabPane"
                 tabClosingPolicy="UNAVAILABLE"
                 BorderPane.alignment="CENTER">
            <tabs>

                <Tab fx:id="tabHome" text="Home">
                    <content>
                        <fx:include fx:id="homeView" source="HomeView.fxml"/>
                    </content>
                </Tab>

                <Tab fx:id="tabCourses" text="Courses">
                    <content>
                        <fx:include fx:id="coursesView" source="CourseView.fxml"/>
                    </content>
                </Tab>

                <Tab fx:id="tabCalendar" text="Calendar">
                    <content>
                        <fx:include fx:id="calendarView" source="CalendarView.fxml"/>
                    </content>
                </Tab>

                <Tab fx:id="tabPomodoro" text="Timer">
                    <content>
                        <fx:include fx:id="timerView" source="TimerView.fxml"/>
                    </content>
                </Tab>

                <Tab fx:id="tabTodo" text="ToDo">
                    <content>
                        <fx:include fx:id="todoView" source="TodoView.fxml"/>
                    </content>
                </Tab>

                <Tab fx:id="tabStats" text="Statistics">
                    <content>
                        <fx:include fx:id="statisticsView" source="StatisticsView.fxml"/>
                    </content>
                </Tab>

            </tabs>
        </TabPane>
    </center>

    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="8" styleClass="bottom-bar">
            <Region HBox.hgrow="ALWAYS" />
            <Button fx:id="themeToggleButton"
                    mnemonicParsing="false"
                    onAction="#handleThemeToggle"
                    text="Light Mode"
                    styleClass="theme-toggle-button"/>
        </HBox>
    </bottom>
</BorderPane>