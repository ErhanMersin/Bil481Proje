<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" style="-fx-background-color: #2d2d2d; -fx-padding: 20;"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fellow.app.controller.AddEventController">
    
    <Label text="Add New Event" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" />
    
    <GridPane hgap="10" vgap="10">
        <Label text="Title:" textFill="#bbbbbb" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtTitle" promptText="Event Name" style="-fx-background-color: #3a3a3a; -fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Type:" textFill="#bbbbbb" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <ComboBox fx:id="cmbType" style="-fx-background-color: #3a3a3a; -fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
        
        <Label text="Date:" textFill="#bbbbbb" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <DatePicker fx:id="dpDate" style="-fx-control-inner-background: #3a3a3a;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Time (Optional):" textFill="#bbbbbb" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <TextField fx:id="txtTime" promptText="e.g. 14:30" style="-fx-background-color: #3a3a3a; -fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        
        <Label text="Desc (Optional):" textFill="#bbbbbb" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="txtDesc" promptText="Details..." style="-fx-background-color: #3a3a3a; -fx-text-fill: white;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" style="-fx-background-color: #555555; -fx-text-fill: white;" />
        <Button text="Save Event" onAction="#handleSave" style="-fx-background-color: #f39c12; -fx-text-fill: white; -fx-font-weight: bold;" />
    </HBox>
</VBox>
