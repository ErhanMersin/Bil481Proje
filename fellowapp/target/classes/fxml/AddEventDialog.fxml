<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" alignment="CENTER" styleClass="form-card"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.fellow.app.controller.AddEventController">
    
    <Label text="Add New Event" styleClass="section-title" />
    
    <GridPane hgap="10" vgap="10">
        <Label text="Title:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="0" />
        <TextField fx:id="txtTitle" promptText="Event Name" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="0" />
        
        <Label text="Type:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="1" />
        <ComboBox fx:id="cmbType" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="1" />

        <Label text="Course:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="2" />
        <ComboBox fx:id="cmbCourse" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="2" />
        
        <Label text="Date:" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="3" />
        <DatePicker fx:id="dpDate" styleClass="date-picker" GridPane.columnIndex="1" GridPane.rowIndex="3" />
        
        <Label text="Time (Optional):" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="4" />
        <TextField fx:id="txtTime" promptText="e.g. 14:30" styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="4" />
        
        <Label text="Desc (Optional):" styleClass="form-label" GridPane.columnIndex="0" GridPane.rowIndex="5" />
        <TextField fx:id="txtDesc" promptText="Details..." styleClass="form-textfield" GridPane.columnIndex="1" GridPane.rowIndex="5" />
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancel" onAction="#handleCancel" styleClass="button-reset" />
        <Button text="Save Event" onAction="#handleSave" styleClass="btn-accent" />
    </HBox>
</VBox>
