<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.fellow.app.controller.CourseController">
    <children>
        <SplitPane dividerPositions="0.45" AnchorPane.topAnchor="0.0" AnchorPane.bottomAnchor="0.0"
                   AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0">
            <items>
                <AnchorPane styleClass="form-card">
                    <children>
                        <VBox spacing="15.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
                              AnchorPane.rightAnchor="20.0">
                            <children>
                                <Label text="Add Course" styleClass="section-title"/>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Course Name" styleClass="form-label"/>
                                        <TextField fx:id="txtName" promptText="Enter course name" styleClass="form-textfield"/>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Description" styleClass="form-label"/>
                                        <TextField fx:id="txtDescription" promptText="Enter course description" styleClass="form-textfield"/>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Pick Color" styleClass="form-label"/>
                                        <ColorPicker fx:id="colorPicker" styleClass="form-textfield" />
                                    </children>
                                </VBox>
                                <Button mnemonicParsing="false" onAction="#handleAddCourse" styleClass="btn-primary" text="Save Course" maxWidth="Infinity" />
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
                <AnchorPane styleClass="task-panel">
                    <children>
                        <VBox spacing="15.0" AnchorPane.topAnchor="20.0" AnchorPane.leftAnchor="20.0"
                              AnchorPane.rightAnchor="20.0" AnchorPane.bottomAnchor="20.0">
                            <children>
                                <Label text="Your Courses" styleClass="section-title"/>
                                <ListView fx:id="lvCourses" VBox.vgrow="ALWAYS" />
                            </children>
                        </VBox>
                    </children>
                </AnchorPane>
            </items>
        </SplitPane>
    </children>
</AnchorPane>
