<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane
    xmlns="http://javafx.com/javafx/17"
    xmlns:fx="http://javafx.com/fxml/1"
    fx:controller="com.fellow.app.controller.HomeController"
    style="-fx-background-color: #1e1e1e;">

    <center>
        <VBox spacing="24" alignment="TOP_CENTER">
            <padding>
                <Insets top="32" right="36" bottom="32" left="36"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="16">
                <Label text="Welcome Back!"
                       style="-fx-font-size: 26px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                <Label fx:id="lblDate" text=""
                       style="-fx-font-size: 13px; -fx-text-fill: #888888; -fx-padding: 5 0 0 0;"/>
                
                <Region HBox.hgrow="ALWAYS" />
                <HBox fx:id="miniTimerBox" visible="false" managed="false" alignment="CENTER" spacing="8" 
                      onMouseClicked="#handleMiniTimerClick"
                      style="-fx-background-color: #2c3e50; -fx-padding: 5 15; -fx-background-radius: 20; -fx-border-color: #f39c12; -fx-border-radius: 20; -fx-border-width: 2; -fx-cursor: hand;">
                    <Label text="⏱" style="-fx-text-fill: #f39c12; -fx-font-size: 18px;"/>
                    <Label fx:id="lblMiniTimer" text="25:00" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                </HBox>
            </HBox>

            <Separator style="-fx-background-color: #2d2d2d;"/>

            <!-- Stat cards -->
            <GridPane hgap="16" vgap="0">
                <columnConstraints>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                    <ColumnConstraints percentWidth="33.33"/>
                </columnConstraints>
                <rowConstraints>
                    <RowConstraints minHeight="95"/>
                </rowConstraints>

                <!-- Card 1: Study Time -->
                <VBox GridPane.columnIndex="0" GridPane.rowIndex="0"
                      alignment="CENTER" spacing="6"
                      onMouseClicked="#handleStartTimer"
                      style="-fx-background-color: #2d2d2d; -fx-background-radius: 10; -fx-padding: 16; -fx-cursor: hand;">
                    <Label text="Today's Study Time"
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;"/>
                    <Label fx:id="lblStudyTime" text="0h 0m"
                           style="-fx-text-fill: #1d8fbd; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Card 2: Pomodoros -->
                <VBox GridPane.columnIndex="1" GridPane.rowIndex="0"
                      alignment="CENTER" spacing="6"
                      onMouseClicked="#handleStartTimer"
                      style="-fx-background-color: #2d2d2d; -fx-background-radius: 10; -fx-padding: 16; -fx-cursor: hand;">
                    <Label text="Pomodoro's Today"
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;"/>
                    <Label fx:id="lblPomodoros" text="0"
                           style="-fx-text-fill: #1d8fbd; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>

                <!-- Card 3: Active ToDos -->
                <VBox GridPane.columnIndex="2" GridPane.rowIndex="0"
                      alignment="CENTER" spacing="6"
                      onMouseClicked="#handleAddTodo"
                      style="-fx-background-color: #2d2d2d; -fx-background-radius: 10; -fx-padding: 16; -fx-cursor: hand;">
                    <Label text="Active ToDo's"
                           style="-fx-text-fill: #aaaaaa; -fx-font-size: 11px;"/>
                    <Label fx:id="lblActiveTodos" text="0"
                           style="-fx-text-fill: #1d8fbd; -fx-font-size: 24px; -fx-font-weight: bold;"/>
                </VBox>
            </GridPane>

            <!-- Quick action buttons -->
            <HBox spacing="14" alignment="CENTER_LEFT">
                <Button text="Start Pomodoro"
                        onAction="#handleStartTimer"
                        styleClass="btn-primary"/>
                <Button text="Add ToDo"
                        onAction="#handleAddTodo"
                        styleClass="btn-primary"/>
                <Button text="Add Event"
                        onAction="#handleAddEvent"
                        styleClass="btn-primary" style="-fx-background-color: #f39c12;"/>
            </HBox>

            <Separator style="-fx-background-color: #2d2d2d;"/>

            <!-- Upcoming events -->
            <VBox spacing="10">
                <HBox alignment="CENTER_LEFT" spacing="15">
                    <Label text="Upcoming Events"
                           style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #ffffff;"/>
                    <Region HBox.hgrow="ALWAYS" />
                    <ComboBox fx:id="cmbSortEvents" promptText="Sıralama Seç" style="-fx-background-color: #3a3a3a; -fx-text-fill: white;" />
                </HBox>
                <ListView fx:id="listUpcomingEvents"
                          prefHeight="200"
                          style="-fx-background-color: #2d2d2d; -fx-background-radius: 8;
                                 -fx-border-color: #3a3a3a; -fx-border-radius: 8;"/>
            </VBox>

        </VBox>
    </center>
</BorderPane>