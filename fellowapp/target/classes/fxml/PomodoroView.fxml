<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<AnchorPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
            fx:controller="com.fellow.app.controller.TimerController">
    <children>
        <VBox alignment="CENTER" spacing="40.0" AnchorPane.bottomAnchor="0.0"
              AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <HBox alignment="CENTER" spacing="30.0">
                    <children>
                        <Button onAction="#handleDecrementTime" text="-" styleClass="round-icon-button"/>
                        <Label fx:id="timerLabel" text="25:00" textAlignment="CENTER" minWidth="220" alignment="CENTER">
                            <font>
                                <Font name="System Bold" size="80.0"/>
                            </font>
                        </Label>
                        <Button onAction="#handleIncrementTime" text="+" styleClass="round-icon-button"/>
                    </children>
                </HBox>
                <HBox alignment="CENTER" nodeOrientation="RIGHT_TO_LEFT" spacing="20.0">
                    <children>
                        <Button fx:id="resetButton" onAction="#handleReset" styleClass="button-reset" text="Reset"/>
                        <Button fx:id="pauseButton" onAction="#handlePause" styleClass="button-pause" text="Pause"/>
                        <Button fx:id="startButton" onAction="#handleStart" styleClass="button-start" text="Start"/>
                    </children>
                </HBox>
            </children>
        </VBox>
        <Button AnchorPane.topAnchor="15.0" AnchorPane.rightAnchor="15.0" onAction="#handleMiniMode" text="⤢" styleClass="icon-button" />
    </children>
</AnchorPane>